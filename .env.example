# Copia este archivo a .env y ajusta los valores

# App
APP_NAME=Sistema Predictivo API
DEBUG=false

# JWT (cambiar JWT_SECRET_KEY en producción)
JWT_SECRET_KEY=cambiar-en-produccion-clave-secreta-muy-segura
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# PostgreSQL 17
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password
POSTGRES_DB=sistema_predictivo_bd

# Supabase Storage (artefactos ML — requerido en producción, opcional en local si ya tienes los .pkl)
SUPABASE_PROJECT_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ml-models
GDRIVE_ITER_IMPUTER_ID=
